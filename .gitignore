# RocketMind Ignore
.rocketmind/state/*
!.rocketmind/
!.rocketmind/state/
!.rocketmind/state/.gitkeep
!.rocketmind/state/STATE.md
.rocketmind/hooks/*
!.rocketmind/hooks/.gitkeep
.rocketmind/errors/
.rocketmind/context.db
.rocketmind/adapters/
.rocketmind/state/sessions.log
.rocketmind/state/tool-usage.log
.rocketmind/state/compact.log
.rocketmind/reports/

# Git Worktrees
.worktrees/

# Test coverage output (generated by vitest --coverage)
coverage/

# OS/Node
node_modules/
.DS_Store
*.log
.rocketmind.lock

# Generated at release time — not source
/RELEASE_NOTES.md

# Coding agent install artifacts — machine-specific, generated by install.sh
# Never commit these. Run `bash install.sh --local --tool <name>` to regenerate.
.claude/
.codex/
.cursor/
.windsurf/
.antigravity/

# AGENTS.md — eliminated in v2.8.0, replaced by generated CLAUDE.md/INSTRUCTIONS.md
# Guard against accidental re-creation by old installers or manual copies
AGENTS.md

# Root CLAUDE.md — generated by install.sh at setup time, not a source file.
# RocketMind is runtime-agnostic: tool-specific files live in .claude/, .codex/, etc.
# Regenerate: npm run setup -- --tool claude
CLAUDE.md
